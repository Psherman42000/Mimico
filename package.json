{
  "name": "mimico",
  "version": "1.0.0",
  "description": "Real-time audio transcription & translation overlay for meetings",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/main/*.html\" \"dist/\"",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "lint": "eslint src/"
  },
  "author": "Pedro",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "copyfiles": "^2.4.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.52.0"
  }
}
